{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["peer-js-server.js", "src/main.tsx", "vite-plugin-html-prerender/src/**/*.ts", "scripts/**/*.ts"],
  "project": [
    "src/**/*.{js,jsx,ts,tsx}",
    "vite-plugin-html-prerender/src/**/*.ts",
    "!src/**/*.{test,spec,tests,ct-story,stories}.{js,jsx,ts,tsx}",
    "!src/__tests__/**",
    "!src/**/*.d.ts"
  ],
  "ignore": [
    "src/modules/elements/layout-with-background-emotion.tsx",
    "src/modules/game-engine/input/mic-strategies/yin.ts",
    "src/modules/remote-mic/network/client/transport/peer-js-client.ts",
    "src/modules/remote-mic/network/server/transport/peer-js-server.ts",
    "src/modules/songs/utils/song-fixture.ts",
    "src/modules/hooks/use-callback-debugger.ts",
    "src/modules/hooks/use-effect-debugger.ts",
    "src/modules/hooks/use-memo-debugger.ts",
    "src/modules/utils/test-canvas.tsx",
    "src/modules/utils/delay-promise.ts",
    "src/modules/utils/iso-code-to-country.ts",
    "src/modules/utils/peer-js-options.ts",
    "src/modules/utils/test-utils.ts",
    "src/modules/utils/use-feature-flag.ts",
    "src/routes/sing-a-song/song-selection/hooks/use-playlists-eurovision.tsx",
    "src/setup-tests.ts",
    "src/stories/song-fixture.ts",
    "src/routes/social-media-elements/social-media-elements.tsx:10",
    "functions/**/*.test.ts"
  ],
  "ignoreDependencies": [
    "vite-tsconfig-paths",
    "@mui/system",
    "peerjs",
    "tailwindcss-motion",
    "html-minifier",
    "@cloudflare/workers-types",
    "wrangler",
    "serve"
  ],
  "ignoreExportsUsedInFile": true,
  "paths": {
    "~/*": ["src/*"]
  }
}
