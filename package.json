    "test-ct": "pnpm playwright test -c playwright-ct.config.mts",
    "peerjs": "pnpm node peer-js-server.js",
    "youtube:duration": "pnpm ts-node scripts/get-youtube-video-duration.ts",
    "songs:backfill-duration": "pnpm ts-node scripts/backfill-song-durations.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "knip": "knip --exclude exports,types,nsExports,nsTypes,classMembers,enumMembers,duplicates,unresolved --no-config-hints",
    "type-check": "tsgo --noEmit",
    "prettier-check": "prettier --config .prettier.config.ci.js src/**/*.{ts,tsx} --check"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
